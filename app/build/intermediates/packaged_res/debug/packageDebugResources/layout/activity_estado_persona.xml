<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1565C0"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Estado de la persona"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_notifications"
            android:tint="#FFFFFF"
            android:layout_marginEnd="12dp"/>

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_account_circle"
            android:tint="#FFFFFF"/>
    </LinearLayout>

    <!-- SUBTITLE -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E3F2FD"
        android:text="Ubicación Actual: Edificio A – Piso 2"
        android:textColor="#1565C0"
        android:textSize="13sp"
        android:paddingStart="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"/>

    <!-- CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <!-- TITULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirmación"
            android:textColor="#1565C0"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <!-- ALTO -->
        <Button
            android:id="@+id/btnAlto"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="ALTO"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#B71C1C"
            android:backgroundTint="#FFCDD2"
            android:layout_marginBottom="12dp"/>

        <!-- MEDIO -->
        <Button
            android:id="@+id/btnMedio"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="MEDIO"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#E65100"
            android:backgroundTint="#FFE0B2"
            android:layout_marginBottom="12dp"/>

        <!-- BAJO -->
        <Button
            android:id="@+id/btnBajo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="BAJO"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:backgroundTint="#C8E6C9"
            android:layout_marginBottom="32dp"/>

        <!-- ENVIAR -->
        <Button
            android:id="@+id/btnEnviarEstado"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Enviar"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A237E"/>

    </LinearLayout>

    <!-- BOTTOM NAVIGATION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1565C0"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_home"
            android:tint="#FFFFFF"/>

        <ImageView
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_cube"
            android:tint="#FFFFFF"/>

        <ImageView
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_shield"
            android:tint="#FFFFFF"/>

        <ImageView
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_warning"
            android:tint="#FF5252"/>
    </LinearLayout>

</LinearLayout>
