<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="URumbox"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.URumbox">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ReportarEmergenciaActivity" android:exported="false" />
        <activity android:name=".EstadoPersonaActivity" android:exported="false" />
        <activity android:name=".RutaEvacuacionActivity" android:exported="false" />
        <activity android:name=".PuntosEncuentroActivity" android:exported="false" />
        <activity android:name=".ConfirmacionActivity" android:exported="false" />
        <activity android:name=".ConfirmacionEstadoActivity" android:exported="false" />
        <activity android:name=".EstadoEnviadoActivity" android:exported="false" />

    </application>

</manifest>