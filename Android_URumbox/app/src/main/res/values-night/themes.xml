<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.URumbox" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Color de la barra de navegación del dispositivo -->
        <item name="android:navigationBarColor">@color/primario</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Color de la barra de estado -->
        <item name="android:statusBarColor">@color/primario</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Forzar color de texto de EditText a texto_principal para evitar problemas de contraste -->
        <item name="editTextColor">@color/texto_principal</item>
        <item name="android:editTextColor">@color/texto_principal</item>
    </style>

    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="iconTint">@color/white</item>
    </style>


    <style name="Theme.URumbox" parent="Base.Theme.URumbox">
        <item name="colorPrimary">@color/azul_ur</item>
        <item name="colorPrimaryVariant">@color/azul_ur</item>
        <item name="colorOnPrimary">@color/blanco</item>
        <item name="colorSecondary">@color/azul_ur</item>
        <item name="colorOnSecondary">@color/blanco</item>
        <item name="colorControlActivated">@color/azul_ur</item>
        <item name="colorControlHighlight">@color/azul_ur</item>
        <item name="colorControlNormal">@color/texto_secundario</item>
    </style>
</resources>