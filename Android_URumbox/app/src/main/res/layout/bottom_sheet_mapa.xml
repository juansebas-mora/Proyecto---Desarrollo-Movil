<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="500dp"
    android:orientation="vertical">

    <!-- Handle + título -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:paddingHorizontal="16dp">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selecciona la ubicación"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/texto_principal"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Toca el mapa para marcar el lugar"
            android:textSize="12sp"
            android:textColor="@color/texto_secundario"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Mapa -->
    <fragment
        android:id="@+id/mapFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Dirección detectada -->
    <TextView
        android:id="@+id/tvDireccionDetectada"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Toca el mapa para seleccionar"
        android:textSize="13sp"
        android:textColor="@color/texto_secundario"
        android:paddingHorizontal="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="4dp"
        android:maxLines="2"
        android:ellipsize="end"/>

    <!-- Botón confirmar -->
    <Button
        android:id="@+id/btnConfirmarUbicacion"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:text="Confirmar ubicación"
        android:backgroundTint="@color/azul_ur"
        android:enabled="false"
        style="@style/Widget.Material3.Button"/>

</LinearLayout>