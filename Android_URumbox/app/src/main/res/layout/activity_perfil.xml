<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/azul_ur">

    <com.example.urumbox.TopbarView
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:topbarTitle="Perfil"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/navbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        android:background="@color/fondo">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- CARD AVATAR -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/blanco"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="28dp"
                    android:paddingBottom="28dp">

                    <FrameLayout
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        >

                        <ImageView
                            android:id="@+id/imgAvatar"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:background="@drawable/bg_avatar"
                            android:contentDescription="Avatar"
                            android:padding="18dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_persona"
                             />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvNombre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Carlos Mendoza"
                        android:textColor="@color/texto_principal"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvRol"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Usuario"
                        android:textColor="@color/texto_secundario"
                        android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD MENÚ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/blanco">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <!-- Ítem: Información Personal -->
                    <LinearLayout
                        android:id="@+id/itemInfoPersonal"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icono_menu"
                            android:contentDescription="Info personal"
                            android:padding="6dp"
                            android:src="@drawable/ic_person"
                            app:tint="@color/azul_ur"
                             />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Información Personal"
                            android:textColor="@color/texto_principal"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Ir"
                            android:src="@drawable/ic_chevron_right"
                             />
                    </LinearLayout>

                    <View
                        android:id="@+id/dividerInfoPersonal"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="0dp"
                        android:background="@color/gris_linea" />

                    <!-- Ítem: Configuración -->
                    <LinearLayout
                        android:id="@+id/itemConfiguracion"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icono_menu"
                            android:contentDescription="Configuración"
                            android:padding="6dp"
                            android:src="@drawable/ic_settings"
                            app:tint="@color/azul_ur"
                             />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Configuración"
                            android:textColor="@color/texto_principal"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Ir"
                            android:src="@drawable/ic_chevron_right"
                             />
                    </LinearLayout>

                    <View
                        android:id="@+id/dividerConfiguracion"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="0dp"
                        android:background="@color/gris_linea" />

                    <!-- Ítem: Usuarios (solo Administrador) -->
                    <LinearLayout
                        android:id="@+id/itemUsuarios"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icono_menu"
                            android:contentDescription="Usuarios"
                            android:padding="6dp"
                            android:src="@drawable/ic_persona"
                            app:tint="@color/azul_ur" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Usuarios"
                            android:textColor="@color/texto_principal"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Ir"
                            android:src="@drawable/ic_chevron_right" />
                    </LinearLayout>

                    <View
                        android:id="@+id/dividerUsuarios"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/gris_linea"
                        android:visibility="gone" />

                    <!-- Ítem: Ver Comentarios (solo Administrador) -->
                    <LinearLayout
                        android:id="@+id/itemVerComentarios"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icono_menu"
                            android:contentDescription="Ver comentarios"
                            android:padding="6dp"
                            android:src="@drawable/ic_info_circle"
                            app:tint="@color/azul_ur" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Ver comentarios"
                            android:textColor="@color/texto_principal"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Ir"
                            android:src="@drawable/ic_chevron_right" />
                    </LinearLayout>

                    <View
                        android:id="@+id/dividerVerComentarios"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/gris_linea"
                        android:visibility="gone" />

                    <!-- Ítem: Validar QR (solo Vigilante) -->
                    <LinearLayout
                        android:id="@+id/itemValidarQR"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icono_menu"
                            android:contentDescription="Validar QR"
                            android:padding="6dp"
                            android:src="@drawable/ic_qrcode"
                            app:tint="@color/azul_ur" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Validar QR"
                            android:textColor="@color/texto_principal"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Ir"
                            android:src="@drawable/ic_chevron_right" />
                    </LinearLayout>

                    <View
                        android:id="@+id/dividerValidarQR"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/gris_linea"
                        android:visibility="gone" />

                    <!-- Ítem: Cerrar Sesión -->
                    <LinearLayout
                        android:id="@+id/itemCerrarSesion"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icono_menu"
                            android:contentDescription="Cerrar sesión"
                            android:padding="6dp"
                            android:src="@drawable/ic_logout"
                            app:tint="@color/azul_ur"
                             />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Cerrar Sesión"
                            android:textColor="@color/rojo_ur"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Ir"
                            android:src="@drawable/ic_chevron_right"
                             />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>


    <!-- ============================= -->
    <!-- BOTTOM NAVIGATION BAR         -->
    <!-- ============================= -->
    <View
        android:layout_width="match_parent"
        android:layout_height="85dp"
        android:background="@color/fondo"
        app:layout_constraintBottom_toBottomOf="parent" />

    <com.example.urumbox.NavbarView
        android:id="@+id/navbar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:layout_constraintTop_toBottomOf="@id/mainContent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>