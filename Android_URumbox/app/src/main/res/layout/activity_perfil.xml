<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo">

    <!-- TOP BAR -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="@color/primario"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Perfil"
            android:textColor="@color/blanco"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnCampana"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_icono_topbar"
            android:src="@drawable/ic_notificationes"
            android:padding="10dp"
            android:contentDescription="Notificaciones" />

        <ImageButton
            android:id="@+id/btnUsuario"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_icono_topbar"
            android:src="@drawable/ic_personaa"
            android:padding="10dp"
            android:contentDescription="Usuario" />
    </LinearLayout>

    <!-- SCROLL para el contenido -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNavBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- CARD AVATAR -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/blanco"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="28dp"
                    android:paddingBottom="28dp">

                    <FrameLayout
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        >

                        <ImageView
                            android:id="@+id/imgAvatar"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:background="@drawable/bg_avatar"
                            android:contentDescription="Avatar"
                            android:padding="18dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_persona"
                             />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvNombre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Carlos Mendoza"
                        android:textColor="@color/texto_principal"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvRol"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Usuario"
                        android:textColor="@color/texto_secundario"
                        android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD MENÚ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/blanco">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <!-- Ítem: Información Personal -->
                    <LinearLayout
                        android:id="@+id/itemInfoPersonal"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icono_menu"
                            android:contentDescription="Info personal"
                            android:padding="6dp"
                            android:src="@drawable/ic_person"
                            app:tint="@color/azul_ur"
                             />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Información Personal"
                            android:textColor="@color/texto_principal"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Ir"
                            android:src="@drawable/ic_chevron_right"
                             />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="0dp"
                        android:background="@color/gris_linea" />

                    <!-- Ítem: Configuración -->
                    <LinearLayout
                        android:id="@+id/itemConfiguracion"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icono_menu"
                            android:contentDescription="Configuración"
                            android:padding="6dp"
                            android:src="@drawable/ic_settings"
                            app:tint="@color/azul_ur"
                             />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Configuración"
                            android:textColor="@color/texto_principal"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Ir"
                            android:src="@drawable/ic_chevron_right"
                             />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="0dp"
                        android:background="@color/gris_linea" />

                    <!-- Ítem: Cerrar Sesión -->
                    <LinearLayout
                        android:id="@+id/itemCerrarSesion"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icono_menu"
                            android:contentDescription="Cerrar sesión"
                            android:padding="6dp"
                            android:src="@drawable/ic_logout"
                            app:tint="@color/azul_ur"
                             />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Cerrar Sesión"
                            android:textColor="@color/rojo_ur"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Ir"
                            android:src="@drawable/ic_chevron_right"
                             />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAvegacion -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/barra"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnNavHome"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/nav_bar_button_background"
            android:src="@drawable/ic_home"
            app:tint="@color/fondo"
            android:contentDescription="Inicio"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnNavBox"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/btnNavBox"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/nav_bar_button_background"
            android:src="@drawable/ic_box"
            app:tint="@color/fondo"
            android:contentDescription="Objetos perdidos"
            app:layout_constraintStart_toEndOf="@+id/btnNavHome"
            app:layout_constraintEnd_toStartOf="@+id/btnNavAccess"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/btnNavAccess"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/nav_bar_button_background"
            android:src="@drawable/icono_seguridad"
            app:tint="@color/fondo"
            android:contentDescription="Accesos"
            app:layout_constraintStart_toEndOf="@+id/btnNavBox"
            app:layout_constraintEnd_toStartOf="@+id/btnNavEmergency"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/btnNavEmergency"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/nav_bar_button_background"
            android:src="@drawable/ic_warning"
            app:tint="@color/fondo"
            android:contentDescription="Emergencias"
            app:layout_constraintStart_toEndOf="@+id/btnNavAccess"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
