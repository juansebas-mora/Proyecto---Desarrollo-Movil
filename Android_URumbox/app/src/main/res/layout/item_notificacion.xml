<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="14dp">

        <!-- Indicador azul (punto no leído) -->
        <View
            android:id="@+id/indicadorNoLeido"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_button_rounded_10"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tvHora"
            android:layout_marginBottom="2dp"/>

        <!-- Hora -->
        <TextView
            android:id="@+id/tvHora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2:30 p.m."
            android:textColor="@color/texto_principal"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/indicadorNoLeido"
            android:layout_marginStart="6dp"/>

        <!-- Badge de tipo (Solicitud / Reunion / Entrega) -->
        <TextView
            android:id="@+id/tvTipo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Solicitud"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:background="@drawable/bg_badge_tipo"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Divider horizontal -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/fondo"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvHora"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Icono de categoría -->
        <ImageView
            android:id="@+id/ivIconoCategoria"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_icono_topbar"
            android:src="@drawable/ic_help_circle"
            android:padding="10dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Nombre -->
        <TextView
            android:id="@+id/tvNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Carlos mendoza"
            android:textColor="@color/texto_principal"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toEndOf="@id/ivIconoCategoria"
            app:layout_constraintEnd_toStartOf="@id/ivPerfil"/>

        <!-- Fecha -->
        <TextView
            android:id="@+id/tvFecha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="31 de Julio de 2026"
            android:textColor="@color/texto_secundario"
            android:textSize="12sp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvNombre"
            app:layout_constraintStart_toEndOf="@id/ivIconoCategoria"
            app:layout_constraintEnd_toStartOf="@id/ivPerfil"/>

        <!-- Área / Departamento -->
        <TextView
            android:id="@+id/tvArea"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Entrada de Visitantes"
            android:textColor="@color/texto_secundario"
            android:textSize="12sp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvFecha"
            app:layout_constraintStart_toEndOf="@id/ivIconoCategoria"
            app:layout_constraintEnd_toStartOf="@id/ivPerfil"/>

        <!-- Avatar del solicitante -->
        <ImageView
            android:id="@+id/ivPerfil"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_personaa"
            android:background="@drawable/bg_icono_topbar"
            android:padding="6dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Botón Ver detalles -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerDetalles"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:text="Ver detalles"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@color/primario"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_details"
            app:iconTint="@color/white"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toBottomOf="@id/ivIconoCategoria"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnAceptar"/>

        <!-- Botón Aceptar (estado normal) -->
        <ImageButton
            android:id="@+id/btnAceptar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_check"
            android:background="@drawable/circle_avatar_background_green"
            android:contentDescription="Aceptar"
            android:padding="8dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toBottomOf="@id/ivIconoCategoria"
            app:layout_constraintEnd_toStartOf="@id/btnRechazar"/>

        <!-- Botón Rechazar (estado normal) -->
        <ImageButton
            android:id="@+id/btnRechazar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_close"
            android:background="@drawable/circle_avatar_background_red"
            android:contentDescription="Rechazar"
            android:padding="8dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/ivIconoCategoria"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Botón Restaurar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRestaurar"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:visibility="gone"
            android:text="Restaurar"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@color/primario"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_restaurar"
            app:iconTint="@color/white"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toBottomOf="@id/ivIconoCategoria"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnEliminarDefinitivo"/>

        <!-- Botón Eliminar definitivamente (estado eliminado) -->
        <ImageButton
            android:id="@+id/btnEliminarDefinitivo"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:visibility="gone"
            android:src="@drawable/ic_close"
            android:background="@drawable/circle_avatar_background_red"
            android:contentDescription="Eliminar definitivamente"
            android:padding="8dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/ivIconoCategoria"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
