<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="8dp"
    app:cardMaxElevation="10dp"
    app:cardBackgroundColor="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <!-- Indicador círculo (no leído) -->
        <View
            android:id="@+id/indicadorNoLeido"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_indicator_unread"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvHora"
            app:layout_constraintBottom_toBottomOf="@id/tvHora" />

        <!-- Hora -->
        <TextView
            android:id="@+id/tvHora"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="16dp"
            android:text="2:30 p.m."
            android:textColor="@color/primario"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/indicadorNoLeido"
            app:layout_constraintEnd_toStartOf="@id/tvTipo"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Badge de tipo -->
        <TextView
            android:id="@+id/tvTipo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_blue_rounded"
            android:paddingStart="10dp"
            android:paddingTop="3dp"
            android:paddingEnd="10dp"
            android:paddingBottom="3dp"
            android:text="Solicitud"
            android:textColor="@color/white"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/tvHora" />

        <!-- Divider horizontal -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:background="@color/fondo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvHora" />

        <!-- Icono de categoría -->
        <ImageView
            android:id="@+id/ivIconoCategoria"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_icono_topbar"
            android:padding="10dp"
            android:src="@drawable/ic_help_circle_white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider" />

        <!-- Avatar del solicitante -->
        <ImageView
            android:id="@+id/ivPerfil"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_icono_topbar"
            android:padding="10dp"
            android:src="@drawable/ic_personaa"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvNombre"
            app:layout_constraintBottom_toBottomOf="@id/tvArea"
            app:layout_constraintVertical_bias="0.333" />

        <!-- Nombre -->
        <TextView
            android:id="@+id/tvNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:text="Carlos mendoza"
            android:textColor="@color/primario"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/ivIconoCategoria"
            app:layout_constraintEnd_toStartOf="@id/ivPerfil"
            app:layout_constraintTop_toBottomOf="@id/divider" />

        <!-- Fecha -->
        <TextView
            android:id="@+id/tvFecha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="16dp"
            android:text="31 de Julio de 2026"
            android:textColor="@color/texto_secundario"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/ivIconoCategoria"
            app:layout_constraintEnd_toStartOf="@id/ivPerfil"
            app:layout_constraintTop_toBottomOf="@id/tvNombre" />

        <!-- Área / Departamento -->
        <TextView
            android:id="@+id/tvArea"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="16dp"
            android:text="Entrada de Visitantes"
            android:textColor="@color/texto_secundario"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/ivIconoCategoria"
            app:layout_constraintEnd_toStartOf="@id/ivPerfil"
            app:layout_constraintTop_toBottomOf="@id/tvFecha" />

        <!-- Botón Ver detalles — chain horizontal con Aceptar y Rechazar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerDetalles"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginTop="10dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Ver detalles"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            app:backgroundTint="@color/primario"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_details"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconTint="@color/white"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnAceptar"
            app:layout_constraintTop_toBottomOf="@id/ivIconoCategoria" />

        <!-- Botón Aceptar -->
        <ImageButton
            android:id="@+id/btnAceptar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="25dp"
            android:background="@drawable/circle_avatar_background_green"
            android:contentDescription="Aceptar"
            android:padding="8dp"
            android:src="@drawable/ic_aceptarnoti"
            app:layout_constraintStart_toEndOf="@id/btnVerDetalles"
            app:layout_constraintEnd_toStartOf="@id/btnRechazar"
            app:layout_constraintTop_toTopOf="@id/btnVerDetalles"
            app:layout_constraintBottom_toBottomOf="@id/btnVerDetalles" />

        <!-- Botón Rechazar -->
        <ImageButton
            android:id="@+id/btnRechazar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="25dp"
            android:background="@drawable/circle_avatar_background_red"
            android:contentDescription="Rechazar"
            android:padding="8dp"
            android:src="@drawable/ic_rechazarnoti"
            app:layout_constraintStart_toEndOf="@id/btnAceptar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnVerDetalles"
            app:layout_constraintBottom_toBottomOf="@id/btnVerDetalles" />

        <!-- Botón Restaurar — chain horizontal con Eliminar (estado eliminado) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRestaurar"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginTop="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Restaurar"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:backgroundTint="@color/primario"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_restaurar_white"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconTint="@color/white"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnEliminarDefinitivo"
            app:layout_constraintTop_toBottomOf="@id/ivIconoCategoria" />

        <!-- Botón Eliminar definitivamente (estado eliminado) -->
        <ImageButton
            android:id="@+id/btnEliminarDefinitivo"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/circle_avatar_background_red"
            android:contentDescription="Eliminar definitivamente"
            android:padding="8dp"
            android:src="@drawable/ic_close"
            android:visibility="gone"
            app:layout_constraintStart_toEndOf="@id/btnRestaurar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnRestaurar"
            app:layout_constraintBottom_toBottomOf="@id/btnRestaurar" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>