<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@drawable/bg_dialog_rounded">

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_check_circle_green"
        android:layout_marginBottom="16dp"
        android:contentDescription="Solicitud registrada"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¡Solicitud registrada!"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/texto_principal"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="El acceso para el visitante fue solicitado exitosamente."
        android:textSize="14sp"
        android:textColor="@color/texto_secundario"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.button.MaterialButton
        style="@style/Widget.App.Button"
        android:id="@+id/btnAceptar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Aceptar"
        android:backgroundTint="@color/azul_ur"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.button.MaterialButton
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:id="@+id/btnConsultarSolicitudes"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Consultar solicitudes"
        app:strokeColor="@color/azul_ur"
        android:textColor="@color/azul_ur"/>

</LinearLayout>
