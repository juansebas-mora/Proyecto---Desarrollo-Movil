<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo">

    <!-- Header -->
    <com.example.urumbox.TopbarView
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:topbarTitle="Objetos Perdidos"/>
    
    <!-- Barra de búsqueda -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primario"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchView"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/search_background"
            app:iconifiedByDefault="false"
            app:queryHint="Buscar objeto o ubicación..."
            app:queryBackground="@android:color/transparent"/>

    </LinearLayout>


    <!-- Filtros -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTodos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Todos"
                android:checked="true"
                android:layout_marginEnd="8dp"
                app:chipBackgroundColor="@color/secundario"
                app:chipStrokeColor="@color/primario"
                android:textColor="@color/white"
                style="@style/Widget.Material3.Chip.Filter"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPerdidos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perdidos"
                app:chipBackgroundColor="@color/secundario"
                app:chipStrokeColor="@color/primario"
                android:textColor="@color/white"
                android:layout_marginEnd="8dp"

                style="@style/Widget.Material3.Chip.Filter"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipEncontrados"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Encontrados"
                app:chipBackgroundColor="@color/secundario"
                app:chipStrokeColor="@color/primario"
                android:textColor="@color/white"
                style="@style/Widget.Material3.Chip.Filter"/>

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Lista de objetos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewObjetos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"/>

    <!-- Botón Reportar Objeto -->
    <Button
        android:id="@+id/btnReportarObjeto"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:text="Reportar Objeto"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="@color/primario"
        style="@style/Widget.Material3.Button"/>

    <!-- NavBar -->
    <!--
    <com.example.urumbox.NavbarView
        android:id="@+id/navbar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_navbar_rounded"
        android:elevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />-->

</LinearLayout>