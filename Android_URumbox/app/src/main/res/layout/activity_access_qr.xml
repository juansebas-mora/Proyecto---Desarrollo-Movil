<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo">

    <!-- ======= -->
    <!-- TOP APP BAR -->
    <!-- ======= -->
    <include
        android:id="@+id/topAppBar"
        layout="@layout/component_topbar"/>

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:background="@null"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="Regresar"
        app:layout_constraintTop_toBottomOf="@id/topAppBar"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- CONTENT AREA -->
    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintBottom_toTopOf="@id/navbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Screen Title -->
        <TextView
            android:id="@+id/tvQrTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="Tu QR de Acceso"
            android:textColor="#1A2E4A"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- QR Code Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardQr"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <ImageView
                android:id="@+id/ivQrCode"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:contentDescription="Código QR de acceso"
                android:src="@drawable/ic_qrcode"
                android:scaleType="fitCenter" />

        </androidx.cardview.widget.CardView>

        <!-- Expiry Date Badge -->
        <TextView
            android:id="@+id/tvValidDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="Valido para: 12/03/2026"
            android:textColor="#C0392B"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ============================= -->
    <!-- BOTTOM NAVIGATION BAR         -->
    <!-- ============================= -->
    <com.example.urumbox.NavbarView
        android:id="@+id/navbar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/barra"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>