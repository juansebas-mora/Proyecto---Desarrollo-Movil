<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Fila: fecha relativa + badge de estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <View
                android:id="@+id/indicadorFecha"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_indicator"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvFechaRelativa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="@color/texto_secundario"/>

            <TextView
                android:id="@+id/tvEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:textSize="11sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Fila: ícono + nombre, ubicación y descripción -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageView
                android:id="@+id/ivObjeto"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/circle_icon_bg"
                android:padding="10dp"
                android:contentDescription="Imagen del objeto"
                android:scaleType="fitCenter"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/texto_principal"/>

                <TextView
                    android:id="@+id/tvUbicacion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/texto_secundario"
                    android:layout_marginTop="2dp"/>

                <!-- Descripción: siempre visible -->
                <TextView
                    android:id="@+id/tvDescripcion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/texto_secundario"
                    android:layout_marginTop="4dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:visibility="visible"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Botones de Acción: Cómo llegar y Detalles (manteniendo tamaño y apariencia del diseño original) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp">

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.App.Button"
                android:id="@+id/btnObjetoRoute"
                android:layout_width="130dp"
                android:layout_height="wrap_content"
                android:text="Cómo llegar"
                android:textAllCaps="false"
                app:cornerRadius="8dp"
                android:backgroundTint="@color/azul_ur"
                android:layout_marginEnd="16dp" />

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.App.Button"
                android:id="@+id/btnObjetoDetails"
                android:layout_width="130dp"
                android:layout_height="wrap_content"
                android:text="Detalles"
                android:textAllCaps="false"
                app:cornerRadius="8dp"
                android:backgroundTint="@color/azul_ur" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
