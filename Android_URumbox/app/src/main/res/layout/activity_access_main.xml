<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/azul_ur">

    <!-- ======= -->
    <!-- TOP APP BAR -->
    <!-- ======= -->
    <com.example.urumbox.TopbarView
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:topbarTitle="Accesos"
        app:showBackButton="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ======= -->
    <!-- CONTENT -->
    <!-- ======= -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="15dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@+id/topBar"
        app:layout_constraintBottom_toTopOf="@+id/navbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@color/fondo">

        <!-- ========================= -->
        <!-- USER PROFILE CARD         -->
        <!-- ========================= -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardUserProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/fondo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/cardAccessHistory"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <!-- PHOTO -->
                <FrameLayout
                    android:id="@+id/avatarContainer"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_avatar"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <ImageView
                        android:id="@+id/ivUserAvatar"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_persona"
                        android:contentDescription="Avatar"/>

                </FrameLayout>

                <!-- User Name -->
                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Carlos Mendoza"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/azul_ur"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toEndOf="@+id/avatarContainer"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/avatarContainer"
                    app:layout_constraintBottom_toTopOf="@+id/tvUserEmail" />

                <!-- User CC -->
                <TextView
                    android:id="@+id/tvUserEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="test.test@urosario.edu.co"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintStart_toEndOf="@+id/avatarContainer"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvUserName"
                    app:layout_constraintBottom_toBottomOf="@+id/avatarContainer" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.cardview.widget.CardView>

        <!-- ========================= -->
        <!-- ACCESS HISTORY CARD       -->
        <!-- ========================= -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardAccessHistory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/fondo"
            app:layout_constraintTop_toBottomOf="@+id/cardUserProfile"
            app:layout_constraintBottom_toTopOf="@+id/btnAddVisitor"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/accessHistoryQuickView"
                android:layout_height="341dp"
                android:padding="16dp">

                <!-- Header Title -->
                <TextView
                    android:id="@+id/tvHistoryTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Historial de accesos"
                    android:textColor="@color/azul_ur"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@+id/btnViewAllHistory"
                    app:layout_constraintEnd_toStartOf="@+id/btnViewAllHistory"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/btnViewAllHistory" />

                <!-- Arrow button -->
                <ImageButton
                    android:id="@+id/btnViewAllHistory"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/content_button"
                    android:contentDescription="Ver todo"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_arrow_forward"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#0D1B3E" />

                <!-- Divider -->
                <View
                    android:id="@+id/dividerHistory"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="#E0E0E0"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/btnViewAllHistory" />

                <!-- Items de historial de accesos -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvQuickHistory"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:overScrollMode="never"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@+id/dividerHistory"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tvQuickHistoryEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sin accesos registrados"
                    android:textColor="@color/texto_secundario"
                    android:textSize="13sp"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@+id/dividerHistory"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.cardview.widget.CardView>

        <!-- ======================= -->
        <!-- ROLE + ADD VISITOR + QR -->
        <!-- ======================= -->
        <ImageButton
            android:id="@+id/btnAddVisitor"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/content_button"
            android:src="@drawable/ic_add"
            android:contentDescription="Agregar visitante"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardAccessHistory"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="@color/azul_ur" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardRoleBadge"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/fondo"
            app:layout_constraintStart_toEndOf="@+id/btnAddVisitor"
            app:layout_constraintEnd_toStartOf="@+id/btnQrCode"
            app:layout_constraintTop_toBottomOf="@+id/cardAccessHistory"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvRoleBadge"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text=""
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/azul_ur" />

        </androidx.cardview.widget.CardView>

        <ImageButton
            android:id="@+id/btnQrCode"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/content_button"
            android:src="@drawable/ic_qrcode"
            android:contentDescription="Código QR"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardAccessHistory"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="@color/azul_ur" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ============================= -->
    <!-- BOTTOM NAVIGATION BAR         -->
    <!-- ============================= -->
    <View
        android:layout_width="match_parent"
        android:layout_height="85dp"
        android:background="@color/fondo"
        app:layout_constraintBottom_toBottomOf="parent" />

    <com.example.urumbox.NavbarView
        android:id="@+id/navbar"
        android:layout_width="match_parent"
        android:layout_height="85dp"
        android:background="@color/barra"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>