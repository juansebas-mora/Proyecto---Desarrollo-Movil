<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primario">

    <!-- Contenido centrado verticalmente -->
    <LinearLayout
        android:id="@+id/contenidoCentro"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/contenidoBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo UR -->
        <androidx.cardview.widget.CardView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#162d55">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="UR"
                android:textColor="@color/rojo_ur"
                android:textSize="28sp"
                android:textStyle="bold" />

        </androidx.cardview.widget.CardView>

        <!-- Nombre app -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="URumbox"
            android:textColor="@color/blanco"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Universidad -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Universidad del Rosario"
            android:textColor="#CCDDEE"
            android:textSize="14sp" />

        <!-- Slogan -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Navega tu campus fácilmente"
            android:textColor="#CCDDEE"
            android:textSize="14sp" />

        <!-- Línea roja decorativa -->
        <View
            android:layout_width="40dp"
            android:layout_height="3dp"
            android:layout_marginTop="16dp"
            android:layout_gravity="center"
            android:background="@color/rojo_ur" />

    </LinearLayout>

    <!-- Botones abajo -->
    <LinearLayout
        android:id="@+id/contenidoBottom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:paddingBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Botón Inicio sesión -->
        <Button
            android:id="@+id/btnInicioSesion"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Inicio sesión"
            android:textColor="@color/azul_ur"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/blanco"
            android:stateListAnimator="@null"
            app:cornerRadius="12dp" />

        <!-- Botón Registrarse -->
        <Button
            android:id="@+id/btnRegistrarse"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="Registrarse"
            android:textColor="@color/blanco"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/rojo_ur"
            android:stateListAnimator="@null"
            app:cornerRadius="12dp" />

        <!-- Versión -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="v1.0.0"
            android:textColor="#7A9BBF"
            android:textSize="12sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>