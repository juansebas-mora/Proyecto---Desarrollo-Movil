<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="107dp"
        android:background="#1B3E63"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Estado de la persona"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnNotification"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/topbar_button_background"
            android:src="@drawable/ic_notifications"
            android:contentDescription="@string/notifications_description"
            app:tint="@color/blanco"
            app:layout_constraintBottom_toBottomOf="@+id/tvTitle"
            app:layout_constraintEnd_toStartOf="@+id/btnProfile"
            app:layout_constraintTop_toTopOf="@+id/tvTitle" />

        <ImageButton
            android:id="@+id/btnProfile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/topbar_button_background"
            android:src="@drawable/ic_profile"
            android:contentDescription="@string/profile_description"
            app:tint="@color/blanco"
            app:layout_constraintBottom_toBottomOf="@+id/tvTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvTitle" />
    </LinearLayout>

    <!-- SUBTITLE -->

    <!-- CONTENT -->

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B3E63"
        android:paddingStart="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="Ubicación Actual: Edificio A – Piso 2"
        android:textColor="#FFFFFF"
        android:textSize="20sp" />

    <!-- CONTENIDO -->

    <!-- NAVBAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Ícono check grande -->
        <ImageView
            android:layout_width="200dp"
            android:layout_height="170dp"
            android:layout_marginBottom="24dp"
            android:src="@drawable/ic_check_circle"
            app:tint="#4CAF50" />

        <!-- Texto estado -->

        <!-- Botón volver -->

        <LinearLayout
            android:layout_width="272dp"
            android:layout_height="83dp"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_check_circle"
                app:tint="#4CAF50" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Tu estado ha sido enviado"
                android:textColor="#000"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginTop="40dp"
            app:backgroundTint="#1B3E63"
            android:background="@drawable/bg_button_volver"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:text="Volver al inicio"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />
    </LinearLayout>

    <com.example.urumbox.NavbarView
        android:id="@+id/navbar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />



</LinearLayout>