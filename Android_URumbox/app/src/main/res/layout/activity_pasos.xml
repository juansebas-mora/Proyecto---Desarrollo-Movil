<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/azul_ur">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/azul_ur"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:paddingTop="25dp"
            android:paddingBottom="25dp"
            android:text="Pasos"
            android:textColor="@color/blanco"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnNotification"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/topbar_button_background"
            android:src="@drawable/ic_notifications"
            android:contentDescription="@string/notifications_description"
            app:layout_constraintBottom_toBottomOf="@+id/tvTitle"
            app:layout_constraintEnd_toStartOf="@+id/btnProfile"
            app:layout_constraintTop_toTopOf="@+id/tvTitle"
            app:tint="@color/blanco" />

        <ImageButton
            android:id="@+id/btnProfile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/topbar_button_background"
            android:src="@drawable/ic_profile"
            android:contentDescription="@string/profile_description"
            app:layout_constraintBottom_toBottomOf="@+id/tvTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvTitle"
            app:tint="@color/blanco" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#F4F7FB"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@+id/navbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:padding="16dp"
            app:layout_constraintBottom_toTopOf="@+id/card_bottom_info"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical"
                android:paddingBottom="12dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="9dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="true"
                    app:strokeColor="#1A000000"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="#F4F7FB">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tvStep1Title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Puerta del salon 301"
                            android:textStyle="bold"
                            android:textColor="@color/azul_ur"
                            android:textSize="16sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/ivStep1Icon" />
                        <TextView
                            android:id="@+id/tvStep1Desc"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Salga por la puerta y gire a la derecha"
                            android:textSize="13sp"
                            android:textColor="#888888"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvStep1Title"
                            app:layout_constraintEnd_toStartOf="@+id/ivStep1Icon" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:layout_width="110dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="12dp"
                            android:text="Volver aquí"
                            android:textSize="12sp"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_button_rounded_10"
                            android:textColor="@color/blanco"
                            android:elevation="2dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvStep1Desc" />

                        <ImageView
                            android:id="@+id/ivStep1Icon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_location_current"
                            android:background="@drawable/bg_status_badge"
                            android:padding="8dp"
                            android:elevation="4dp"
                            app:tint="@color/azul_ur"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="9dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="true"
                    app:strokeColor="#1A000000"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="#F4F7FB">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tvStep2Title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Pasillo piso 3 CASUR"
                            android:textStyle="bold"
                            android:textColor="@color/azul_ur"
                            android:textSize="16sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/ivStep2Icon" />
                        <TextView
                            android:id="@+id/tvStep2Desc"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Recorra el pasillo hasta las escaleras"
                            android:textSize="13sp"
                            android:textColor="#888888"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvStep2Title"
                            app:layout_constraintEnd_toStartOf="@+id/ivStep2Icon" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:layout_width="110dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="12dp"
                            android:text="Estás aquí"
                            android:textSize="12sp"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_button_light_blue_rounded_10"
                            android:textColor="#8E8E93"
                            android:elevation="2dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvStep2Desc" />

                        <ImageView
                            android:id="@+id/ivStep2Icon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_location_current"
                            android:background="@drawable/bg_status_badge"
                            android:padding="8dp"
                            android:elevation="4dp"
                            app:tint="@color/azul_ur"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Paso 3 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="9dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="true"
                    app:strokeColor="#1A000000"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="#F4F7FB">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tvStep3Title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Subir escaleras a Piso 4"
                            android:textStyle="bold"
                            android:textColor="@color/azul_ur"
                            android:textSize="16sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/ivStep3Icon" />
                        <TextView
                            android:id="@+id/tvStep3Desc"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Use las escaleras de la Torre 2 para subir al siguiente nivel"
                            android:textSize="13sp"
                            android:textColor="#888888"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvStep3Title"
                            app:layout_constraintEnd_toStartOf="@+id/ivStep3Icon" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:layout_width="110dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="12dp"
                            android:text="Saltar aquí"
                            android:textSize="12sp"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_button_rounded_10"
                            android:textColor="@color/blanco"
                            android:elevation="2dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvStep3Desc" />

                        <ImageView
                            android:id="@+id/ivStep3Icon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_location_current"
                            android:background="@drawable/bg_status_badge"
                            android:padding="8dp"
                            android:elevation="4dp"
                            app:tint="@color/azul_ur"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Paso 4 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="9dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="true"
                    app:strokeColor="#1A000000"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="#F4F7FB">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tvStep4Title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Pasillo principal Piso 4"
                            android:textStyle="bold"
                            android:textColor="@color/azul_ur"
                            android:textSize="16sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/ivStep4Icon" />
                        <TextView
                            android:id="@+id/tvStep4Desc"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Camine recto por el pasillo pasando los laboratorios de cómputo"
                            android:textSize="13sp"
                            android:textColor="#888888"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvStep4Title"
                            app:layout_constraintEnd_toStartOf="@+id/ivStep4Icon" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:layout_width="110dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="12dp"
                            android:text="Saltar aquí"
                            android:textSize="12sp"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_button_rounded_10"
                            android:textColor="@color/blanco"
                            android:elevation="2dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvStep4Desc" />

                        <ImageView
                            android:id="@+id/ivStep4Icon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_location_current"
                            android:background="@drawable/bg_status_badge"
                            android:padding="8dp"
                            android:elevation="4dp"
                            app:tint="@color/azul_ur"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Paso 5 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="9dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="true"
                    app:strokeColor="#1A000000"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="#F4F7FB">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tvStep5Title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Entrada a Sala 2172"
                            android:textStyle="bold"
                            android:textColor="@color/azul_ur"
                            android:textSize="16sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/ivStep5Icon" />
                        <TextView
                            android:id="@+id/tvStep5Desc"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Has llegado a tu destino. La sala está a mano izquierda del pasillo."
                            android:textSize="13sp"
                            android:textColor="#888888"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvStep5Title"
                            app:layout_constraintEnd_toStartOf="@+id/ivStep5Icon" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:layout_width="110dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="12dp"
                            android:text="Llegué"
                            android:textSize="12sp"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_button_light_blue_rounded_10"
                            android:textColor="#8E8E93"
                            android:elevation="2dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvStep5Desc" />

                        <ImageView
                            android:id="@+id/ivStep5Icon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_location_current"
                            android:background="@drawable/bg_status_badge"
                            android:padding="8dp"
                            android:elevation="4dp"
                            app:tint="@color/azul_ur"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnGoToMapa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:src="@drawable/ic_map_nav"
            android:contentDescription="@string/go_to_maps_description"
            app:backgroundTint="@color/secundario"
            app:tint="@color/blanco"
            app:elevation="8dp"
            app:maxImageSize="32dp"
            app:layout_constraintBottom_toTopOf="@id/card_bottom_info"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_bottom_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/white"
            app:strokeColor="#1A000000"
            app:strokeWidth="1dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvDestinationName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sala 2172 CASUR"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/primario" />

                <TextView
                    android:id="@+id/tvRouteStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Faltan 5 min (500 metros)"
                    android:textSize="14sp"
                    android:textColor="@color/texto_secundario" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/gris_linea" />

                <TextView
                    android:id="@+id/tvNextInstruction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Siguiente: Gira a la derecha en el pasillo principal"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/secundario" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Fondo extra para tapar el azul en los bordes redondeados -->
    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#F4F7FB"
        app:layout_constraintBottom_toBottomOf="parent" />

    <com.example.urumbox.NavbarView
        android:id="@+id/navbar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_navbar_rounded"
        android:elevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>