<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@drawable/bg_dialog_rounded">

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_access"
        app:tint="@color/azul_ur"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvTituloConfirmar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/texto_principal"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvMensajeConfirmar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/texto_secundario"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmarSolicitud"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Confirmar"
        android:textStyle="bold"
        android:textAllCaps="false"
        app:cornerRadius="10dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancelarSolicitud"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Cancelar"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:layout_marginTop="8dp"
        android:textColor="@color/azul_ur"
        style="@style/Widget.Material3.Button.OutlinedButton"
        app:cornerRadius="10dp" />

</LinearLayout>
