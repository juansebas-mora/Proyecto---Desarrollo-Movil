<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo">

    <!-- TOP BAR -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="@color/azul_ur"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_chevron_right"
            android:rotation="180"
            android:contentDescription="Volver"
            app:tint="@color/blanco" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Configuración"
            android:textColor="@color/blanco"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- CONTENIDO -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomNavBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- CARD MENÚ CONFIGURACIÓN -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/blanco">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Permisos -->
                    <LinearLayout
                        android:id="@+id/itemPermisos"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_icono_menu"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/azul_ur"
                            android:padding="8dp"
                            android:contentDescription="Permisos" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="Permisos"
                            android:textColor="@color/texto_principal"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right"
                            android:contentDescription="Ir" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginStart="66dp" android:background="@color/gris_linea" />

                    <!-- Cambiar Contraseña -->
                    <LinearLayout
                        android:id="@+id/itemCambiarContrasena"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_icono_menu"
                            android:src="@drawable/ic_settings"
                            app:tint="@color/azul_ur"
                            android:padding="8dp"
                            android:contentDescription="Contraseña" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="Cambiar Contraseña"
                            android:textColor="@color/texto_principal"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#AAAAAA"
                            android:contentDescription="Ir" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginStart="66dp" android:background="@color/gris_linea" />

                    <!-- Deja un Comentario -->
                    <LinearLayout
                        android:id="@+id/itemComentario"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_icono_menu"
                            android:src="@drawable/ic_person"
                            app:tint="@color/azul_ur"
                            android:padding="8dp"
                            android:contentDescription="Comentario" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="Deja un Comentario"
                            android:textColor="@color/texto_principal"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right"
                            android:contentDescription="Ir" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginStart="66dp" android:background="@color/gris_linea" />

                    <!-- Contáctanos -->
                    <LinearLayout
                        android:id="@+id/itemContactanos"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_icono_menu"
                            android:src="@drawable/ic_contac"
                            android:padding="8dp"
                            android:contentDescription="Contactanos"
                            app:tint="@color/azul_ur" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="Contactanos"
                            android:textColor="@color/texto_principal"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right"
                            android:contentDescription="Ir" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginStart="66dp" android:background="@color/gris_linea" />

                    <!-- Versión de la app -->
                    <LinearLayout
                        android:id="@+id/itemVersion"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_icono_menu"
                            android:src="@drawable/ic_warning"
                            app:tint="@color/azul_ur"
                            android:padding="8dp"
                            android:contentDescription="Version" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="Version de la app"
                            android:textColor="@color/texto_principal"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right"
                            android:contentDescription="Ir" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAvegacion -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/barra"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnNavHome"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/nav_bar_button_background"
            android:src="@drawable/ic_home"
            app:tint="@color/fondo"
            android:contentDescription="Inicio"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnNavBox"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/btnNavBox"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/nav_bar_button_background"
            android:src="@drawable/ic_box"
            app:tint="@color/fondo"
            android:contentDescription="Objetos perdidos"
            app:layout_constraintStart_toEndOf="@+id/btnNavHome"
            app:layout_constraintEnd_toStartOf="@+id/btnNavAccess"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/btnNavAccess"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/nav_bar_button_background"
            android:src="@drawable/icono_seguridad"
            app:tint="@color/fondo"
            android:contentDescription="Accesos"
            app:layout_constraintStart_toEndOf="@+id/btnNavBox"
            app:layout_constraintEnd_toStartOf="@+id/btnNavEmergency"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/btnNavEmergency"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/nav_bar_button_background"
            android:src="@drawable/ic_warning"
            app:tint="@color/fondo"
            android:contentDescription="Emergencias"
            app:layout_constraintStart_toEndOf="@+id/btnNavAccess"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>