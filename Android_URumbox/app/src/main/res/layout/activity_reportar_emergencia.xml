<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="107dp"
        android:background="#1B3E63"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Reportar emergencias"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnNotification"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/topbar_button_background"
            android:src="@drawable/ic_notifications"
            android:contentDescription="@string/notifications_description"
            app:tint="@color/blanco" />

        <ImageButton
            android:id="@+id/btnProfile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/topbar_button_background"
            android:src="@drawable/ic_profile"
            android:contentDescription="@string/profile_description"
            app:tint="@color/blanco" />
    </LinearLayout>

    <!-- SUBTITLE -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B3E63"
        android:paddingStart="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="Ubicación Actual: Edificio A – Piso 2"
        android:textColor="#FFFFFF"
        android:textSize="20sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="467dp"
        android:layout_weight="2"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- BACK BUTTON ROW -->

            <!-- GRID DE TIPOS DE EMERGENCIA -->

            <!-- ENVIAR ALERTA BUTTON -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="0dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnBack"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginTop="0dp"
                    android:background="@drawable/bg_circle_blue"
                    android:padding="0dp"
                    android:text="←"
                    android:textColor="#FFFFFF"
                    android:textSize="45sp"
                    app:backgroundTint="#1B3E63" />
            </LinearLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="20dp"
                android:columnCount="2"
                android:rowCount="2">

                <!-- Incendio -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnIncendio"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="35dp"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_local_fire_department"
                            android:tint="#F44336" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Incendio"
                            android:textColor="#333333"
                            android:textSize="14sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Sismo -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnSismo"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="35dp"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_earthquake"
                            android:tint="#FF9800" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Sismo"
                            android:textColor="#333333"
                            android:textSize="14sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Emergencia médica -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnEmergenciaMedica"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="35dp"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_local_hospital"
                            android:tint="#4CAF50" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:text="Emergencia\nmédica"
                            android:textColor="#333333"
                            android:textSize="14sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Amenaza de seguridad -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnAmenazaSeguridad"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="35dp"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_lock"
                            android:tint="#9C27B0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:text="Amenaza de\nseguridad"
                            android:textColor="#333333"
                            android:textSize="14sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </GridLayout>

            <Button
                android:id="@+id/btnEnviarAlerta"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="5dp"
                android:background="@drawable/bg_button_rounded"
                android:text="Enviar alerta"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"
                app:backgroundTint="#B71C1C" />

            <Button
                android:id="@+id/btnVolverInicio"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="25dp"
                android:background="@drawable/bg_button_rounded"
                android:text="Volver al inicio"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"
                app:backgroundTint="#1B3E63" />

        </LinearLayout>

    </ScrollView>

    <!-- BOTTOM NAVIGATION -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/barra">

        <ImageButton
            android:id="@+id/btnNavHome"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/nav_bar_button_background"
            android:src="@drawable/ic_home"
            android:contentDescription="Inicio"
            app:tint="@color/fondo"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnNavBox"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/btnNavBox"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/nav_bar_button_background"
            android:src="@drawable/ic_box"
            android:contentDescription="Objetos perdidos"
            app:tint="@color/fondo"
            app:layout_constraintStart_toEndOf="@+id/btnNavHome"
            app:layout_constraintEnd_toStartOf="@+id/btnNavAccess"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/btnNavAccess"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/nav_bar_button_background"
            android:src="@drawable/icono_seguridad"
            android:contentDescription="Accesos"
            app:tint="@color/fondo"
            app:layout_constraintStart_toEndOf="@+id/btnNavBox"
            app:layout_constraintEnd_toStartOf="@+id/btnNavEmergency"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/btnNavEmergency"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/nav_bar_button_background"
            android:src="@drawable/ic_warning"
            android:contentDescription="Emergencias"
            app:tint="@color/fondo"
            app:layout_constraintStart_toEndOf="@+id/btnNavAccess"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>