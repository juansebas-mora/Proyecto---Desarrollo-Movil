<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primario">

    <com.example.urumbox.TopbarView
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:topbarTitle="Mapa"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#F4F7FB"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@+id/navbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMap"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeColor="#1A000000"
            app:strokeWidth="1dp"
            app:layout_constraintBottom_toTopOf="@+id/card_bottom_info"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#F5F5F5">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_box"
                    android:alpha="0.1" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnGoToPasos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="16dp"
                    android:src="@drawable/ic_go_to_pasos"
                    android:contentDescription="Ir a pasos"
                    app:backgroundTint="@color/secundario"
                    app:tint="@color/white"
                    app:elevation="4dp"
                    app:maxImageSize="32dp" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_bottom_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/white"
            app:strokeColor="#1A000000"
            app:strokeWidth="1dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvDestinationName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sala 2172 CASUR"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/primario" />

                <TextView
                    android:id="@+id/tvRouteStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Faltan 5 min (500 metros)"
                    android:textSize="14sp"
                    android:textColor="@color/texto_secundario" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/gris_linea" />

                <TextView
                    android:id="@+id/tvNextInstruction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Siguiente: Gira a la derecha en el pasillo principal"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/secundario" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Fondo extra para tapar el azul en los bordes redondeados -->
    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#F4F7FB"
        app:layout_constraintBottom_toBottomOf="parent" />

    <com.example.urumbox.NavbarView
        android:id="@+id/navbar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_navbar_rounded"
        android:elevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
