<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primario">

    <com.example.urumbox.TopbarView
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:topbarTitle="Mapa"
        app:showBackButton="true"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#F4F7FB"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@+id/navbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <!-- Map Container Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMap"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeColor="#1A000000"
            app:strokeWidth="1dp"
            app:layout_constraintBottom_toTopOf="@+id/card_bottom_info"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#F5F5F5">
                <com.example.urumbox.ui.InteractiveMapView
                    android:id="@+id/interactiveMapView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Steps List Container RecyclerView (initially hidden, matches cardMap constraints) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPasos"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/card_bottom_info"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Single Floating Action Button for Seamless Map/Steps transition -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnMapToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            android:src="@drawable/ic_go_to_pasos"
            android:contentDescription="Alternar mapa e instrucciones"
            app:backgroundTint="@color/secundario"
            app:tint="@color/white"
            app:elevation="8dp"
            app:maxImageSize="32dp"
            app:layout_constraintBottom_toTopOf="@id/card_bottom_info"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Card bottom info for active navigation step -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_bottom_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/white"
            app:strokeColor="#1A000000"
            app:strokeWidth="1dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvDestinationName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sala 2172 CASUR"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/primario" />

                <TextView
                    android:id="@+id/tvRouteStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Piso 1 | Paso 1 de 5"
                    android:textSize="16sp"
                    android:textColor="@color/texto_secundario" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/gris_linea" />

                <!-- General Title of active navigation step -->
                <TextView
                    android:id="@+id/tvStepTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Título del Paso"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/primario" />

                <!-- Specific Description of active navigation step -->
                <TextView
                    android:id="@+id/tvNextInstruction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Descripción o instrucción específica del paso"
                    android:textSize="16sp"
                    android:textColor="@color/texto_secundario" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="end">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPrevStep"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Anterior"
                        android:textColor="#64748B" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNextStep"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Siguiente"
                        app:backgroundTint="@color/secundario" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Fondo extra para tapar el azul en los bordes redondeados -->
    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#F4F7FB"
        app:layout_constraintBottom_toBottomOf="parent" />

    <com.example.urumbox.NavbarView
        android:id="@+id/navbar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_navbar_rounded"
        android:elevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
