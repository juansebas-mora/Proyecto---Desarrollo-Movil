<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@drawable/bg_dialog_rounded">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Asignar rol"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/texto_principal"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona el rol para este usuario:"
        android:textSize="14sp"
        android:textColor="@color/texto_secundario"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnRolAdministrador"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Administrador"
        android:textStyle="bold"
        android:textColor="@color/blanco"
        android:backgroundTint="@color/azul_ur"
        android:stateListAnimator="@null"
        style="@style/Widget.Material3.Button"/>

    <Button
        android:id="@+id/btnRolUsuarioUR"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Usuario UR"
        android:textStyle="bold"
        android:textColor="@color/blanco"
        android:backgroundTint="@color/azul_ur"
        android:stateListAnimator="@null"
        android:layout_marginTop="8dp"
        style="@style/Widget.Material3.Button"/>

    <Button
        android:id="@+id/btnRolVigilante"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Vigilante"
        android:textStyle="bold"
        android:textColor="@color/blanco"
        android:backgroundTint="@color/azul_ur"
        android:stateListAnimator="@null"
        android:layout_marginTop="8dp"
        style="@style/Widget.Material3.Button"/>

    <Button
        android:id="@+id/btnCancelar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Cancelar"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        android:textColor="@color/azul_ur"
        android:backgroundTint="@color/blanco"
        style="@style/Widget.Material3.Button.OutlinedButton"/>

</LinearLayout>
