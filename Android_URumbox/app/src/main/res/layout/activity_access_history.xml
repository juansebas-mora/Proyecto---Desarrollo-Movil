<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <!-- ======= -->
    <!-- TOP APP BAR -->
    <!-- ======= -->
    <include
        android:id="@+id/topAppBar"
        layout="@layout/component_topbar"/>


    <!-- CONTENT CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardHistorial"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/topAppBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@null"
                    android:src="@drawable/ic_arrow_back"
                    android:contentDescription="Regresar" />

                <TextView
                    android:id="@+id/tvCardTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Historial de Accesos"
                    android:textColor="#1A2E4A"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Access Item 1 -->
            <LinearLayout
                android:id="@+id/itemAcceso1"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_access_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Edificio El Tiempo"
                    android:textColor="#1A2E4A"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12:37"
                    android:textColor="#1A2E4A"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Access Item 2 -->
            <LinearLayout
                android:id="@+id/itemAcceso2"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_access_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Edificio Cabal"
                    android:textColor="#1A2E4A"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="14:38"
                    android:textColor="#1A2E4A"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Access Item 3 -->
            <LinearLayout
                android:id="@+id/itemAcceso3"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_access_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Edificio Santa Fe"
                    android:textColor="#1A2E4A"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15:37"
                    android:textColor="#1A2E4A"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Access Item 4 -->
            <LinearLayout
                android:id="@+id/itemAcceso4"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_access_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Edificio El Tiempo"
                    android:textColor="#1A2E4A"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="16:58"
                    android:textColor="#1A2E4A"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Access Item 5 -->
            <LinearLayout
                android:id="@+id/itemAcceso5"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_access_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Edificio El Tiempo"
                    android:textColor="#1A2E4A"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="18:27"
                    android:textColor="#1A2E4A"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ============================= -->
    <!-- BOTTOM NAVIGATION BAR         -->
    <!-- ============================= -->
    <com.example.urumbox.NavbarView
        android:id="@+id/navbar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/barra"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>