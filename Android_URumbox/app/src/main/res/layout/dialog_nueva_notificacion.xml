<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Encabezado con título y botón X -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="8dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="center_vertical"
                android:paddingEnd="32dp">

                <TextView
                    android:id="@+id/tvDialogTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nuevo aviso de ruta"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/primario"
                    android:gravity="start" />

                <TextView
                    android:id="@+id/tvDialogSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Completa los campos para publicar un aviso"
                    android:textSize="12sp"
                    android:textColor="@color/texto_secundario"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/btnCerrarDialog"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="end|top"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_close_black"
                android:padding="6dp"
                android:contentDescription="Cerrar" />

        </FrameLayout>

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gris_linea"
            android:layout_marginBottom="20dp" />

        <!-- Cuerpo del formulario -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <!-- Tipo de aviso -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIPO DE AVISO"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:textColor="@color/primario"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginBottom="20dp">

                <Spinner
                    android:id="@+id/spinnerTipo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:paddingStart="12dp"
                    android:paddingEnd="40dp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_arrow_down"
                    android:contentDescription="@null" />

            </FrameLayout>

            <!-- Zona afectada -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ZONA AFECTADA"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:textColor="@color/primario"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etNuevoArea"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_field"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="Ej: Pasillo B, Piso 2"
                android:textColorHint="@color/texto_secundario"
                android:textColor="@color/primario"
                android:textSize="14sp"
                android:inputType="text"
                android:layout_marginBottom="20dp" />

            <!-- Ubicación exacta -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UBICACIÓN EXACTA"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:textColor="@color/primario"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etNuevaUbicacion"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_field"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="Ej: Entrada norte, frente al ascensor"
                android:textColorHint="@color/texto_secundario"
                android:textColor="@color/primario"
                android:textSize="14sp"
                android:inputType="text"
                android:layout_marginBottom="20dp" />

            <!-- Descripción -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DESCRIPCIÓN DEL AVISO"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:textColor="@color/primario"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etNuevoAsunto"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/bg_input_field"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:hint="Describe brevemente el aviso"
                android:textColorHint="@color/texto_secundario"
                android:textColor="@color/primario"
                android:textSize="14sp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:layout_marginBottom="20dp" />

            <!-- Hora estimada de resolución -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="HORA EST. DE RESOLUCIÓN"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:textColor="@color/primario" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Opcional"
                    android:textSize="11sp"
                    android:textColor="@color/blanco"
                    android:background="@drawable/bg_button_blue_rounded"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llHoraExpiracion"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_field"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="false"
                android:layout_marginBottom="20dp">

                <EditText
                    android:id="@+id/etHoraExpiracion"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp"
                    android:hint="Toca para elegir la hora"
                    android:textColorHint="@color/texto_secundario"
                    android:textColor="@color/primario"
                    android:textSize="14sp"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="true"
                    android:cursorVisible="false" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_fechanoti"
                    android:alpha="0.6"
                    android:contentDescription="@null" />

            </LinearLayout>

            <!-- Prioridad -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRIORIDAD"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:textColor="@color/primario"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginBottom="28dp">

                <Spinner
                    android:id="@+id/spinnerPrioridad"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:paddingStart="12dp"
                    android:paddingEnd="40dp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_arrow_down"
                    android:contentDescription="@null" />

            </FrameLayout>

            <!-- Botón Publicar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCrearNotificacion"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Publicar aviso"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@color/primario"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_add"
                app:iconTint="@color/white"
                app:iconGravity="textStart"
                app:iconPadding="6dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
