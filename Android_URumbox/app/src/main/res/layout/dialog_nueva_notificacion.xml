<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nuevo aviso de ruta"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/texto_general"
            android:gravity="center" />

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/fondo"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Tipo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipo de aviso"
            android:textSize="12sp"
            android:textColor="@color/texto_opaco"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerTipo"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_search"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="14dp" />

        <!-- Zona afectada -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zona afectada"
            android:textSize="12sp"
            android:textColor="@color/texto_opaco"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etNuevoArea"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_search"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:hint="Ej: Pasillo B, Piso 2"
            android:textColorHint="@color/texto_opaco"
            android:textColor="@color/texto_general"
            android:textSize="14sp"
            android:inputType="text"
            android:layout_marginBottom="14dp" />

        <!-- Descripción -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descripción del aviso"
            android:textSize="12sp"
            android:textColor="@color/texto_opaco"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etNuevoAsunto"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_search"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:hint="Describe brevemente el aviso"
            android:textColorHint="@color/texto_opaco"
            android:textColor="@color/texto_general"
            android:textSize="14sp"
            android:inputType="text"
            android:layout_marginBottom="14dp" />

        <!-- Hora estimada de resolución -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hora estimada de resolución (opcional)"
            android:textSize="12sp"
            android:textColor="@color/texto_opaco"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etHoraExpiracion"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_search"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:hint="Ej: 3:00 p.m."
            android:textColorHint="@color/texto_opaco"
            android:textColor="@color/texto_general"
            android:textSize="14sp"
            android:inputType="text"
            android:layout_marginBottom="14dp" />

        <!-- Prioridad -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prioridad"
            android:textSize="12sp"
            android:textColor="@color/texto_opaco"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerPrioridad"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_search"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="20dp" />

        <!-- Botón Publicar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCrearNotificacion"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Publicar aviso"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@color/primario"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_add"
            app:iconTint="@color/white"
            app:iconGravity="textStart"
            app:iconPadding="6dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
