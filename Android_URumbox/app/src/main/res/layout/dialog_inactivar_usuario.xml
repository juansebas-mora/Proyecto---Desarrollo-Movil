<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@drawable/bg_dialog_rounded">

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_warning"
        app:tint="@color/text_medio"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvTituloInactivar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Inactivar usuario"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/texto_principal"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvMensajeInactivar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:textColor="@color/texto_secundario"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnConfirmarInactivar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Confirmar"
        android:textStyle="bold"
        android:textColor="@color/blanco"
        android:backgroundTint="@color/rojo_ur"
        android:stateListAnimator="@null"
        style="@style/Widget.Material3.Button"/>

    <Button
        android:id="@+id/btnCancelarInactivar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Cancelar"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        android:textColor="@color/azul_ur"
        android:backgroundTint="@color/blanco"
        style="@style/Widget.Material3.Button.OutlinedButton"/>

</LinearLayout>
