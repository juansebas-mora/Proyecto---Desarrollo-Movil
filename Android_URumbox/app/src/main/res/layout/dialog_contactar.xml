<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="28dp"
    android:background="@drawable/bg_dialog_rounded">

    <!-- Título -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Datos de Contacto"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/texto_principal"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Comunícate con el propietario"
        android:textSize="13sp"
        android:textColor="@color/texto_secundario"
        android:layout_marginBottom="20dp"/>

    <!-- Avatar -->
    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_person"
        android:background="@drawable/bg_avatar"
        android:padding="12dp"
        android:layout_marginBottom="12dp"/>

    <!-- Nombre -->
    <TextView
        android:id="@+id/tvDialogNombre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/texto_principal"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <!-- Teléfono -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_input"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="8dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_phone"
            android:layout_marginEnd="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Teléfono"
                android:textSize="10sp"
                android:textColor="@color/texto_secundario"/>

            <TextView
                android:id="@+id/tvDialogTelefono"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/texto_principal"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Correo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_input"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="24dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_email"
            android:layout_marginEnd="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Correo Electrónico"
                android:textSize="10sp"
                android:textColor="@color/texto_secundario"/>

            <TextView
                android:id="@+id/tvDialogCorreo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/texto_principal"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Botón cerrar -->
    <Button
        android:id="@+id/btnCerrarContactar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Cerrar"
        android:textStyle="bold"
        android:backgroundTint="@color/azul_ur"
        style="@style/Widget.Material3.Button"/>

</LinearLayout>