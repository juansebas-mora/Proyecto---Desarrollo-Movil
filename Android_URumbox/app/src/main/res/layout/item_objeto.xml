<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Fila: fecha relativa + badge de estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <View
                android:id="@+id/indicadorFecha"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_indicator"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvFechaRelativa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="@color/texto_secundario"/>

            <TextView
                android:id="@+id/tvEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:textSize="11sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Fila: ícono + nombre, ubicación y descripción -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageView
                android:id="@+id/ivObjeto"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/circle_icon_bg"
                android:padding="10dp"
                android:contentDescription="Imagen del objeto"
                android:scaleType="fitCenter"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/texto_principal"/>

                <TextView
                    android:id="@+id/tvUbicacion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/texto_secundario"
                    android:layout_marginTop="2dp"/>

                <!-- Descripción: solo visible para objetos PERDIDOS -->
                <TextView
                    android:id="@+id/tvDescripcion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/texto_secundario"
                    android:layout_marginTop="4dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:visibility="gone"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Botón Ver detalles -->
        <Button
            android:id="@+id/btnVerDetalles"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Ver detalles"
            android:textSize="13sp"
            android:paddingHorizontal="16dp"
            android:backgroundTint="@color/primario"
            style="@style/Widget.Material3.Button"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
