<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@drawable/bg_dialog_rounded">

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_info_circle"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recuperar contraseña"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/texto_principal"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Para restablecer tu contraseña, contacta al soporte técnico de URumbox enviando un correo a:"
        android:textSize="14sp"
        android:textColor="@color/texto_secundario"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvCorreoSoporte"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="urumbox@gmail.com"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/secundario"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="indicando tu correo institucional."
        android:textSize="14sp"
        android:textColor="@color/texto_secundario"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnEntendido"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Entendido"
        android:textStyle="bold"
        android:backgroundTint="@color/azul_ur"
        style="@style/Widget.Material3.Button"/>

</LinearLayout>
